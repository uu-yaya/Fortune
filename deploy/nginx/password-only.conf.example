# Password-only reverse proxy template for ECS.
# Replace example.com and certificate paths before use.

server {
    listen 80;
    server_name example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name example.com;

    ssl_certificate /etc/nginx/ssl/example.com/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/example.com/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    charset utf-8;
    client_max_body_size 10m;

    # Harden auth cookie issued by upstream.
    proxy_cookie_flags jiyi_auth_token secure httponly samesite=lax;

    # Disable SMS/register/reset entry points for password-only launch.
    location = /register        { return 302 /login; }
    location = /forgot-password { return 302 /login; }
    location = /reset-password  { return 302 /login; }

    location = /auth/send_code {
        default_type application/json;
        return 410 '{"ok":false,"message":"当前仅支持账号密码登录"}';
    }

    location = /auth/verify {
        default_type application/json;
        return 410 '{"ok":false,"message":"当前仅支持账号密码登录"}';
    }

    location = /auth/password/verify_code {
        default_type application/json;
        return 410 '{"ok":false,"message":"当前暂不支持短信找回密码"}';
    }

    location = /auth/password/reset {
        default_type application/json;
        return 410 '{"ok":false,"message":"当前暂不支持短信找回密码"}';
    }

    location / {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
