# Password-only production env template (ECS + docker compose).
# Copy this file to .env on the target server and fill real secrets.

# LLM
DASHSCOPE_API_KEY=replace_me

# Optional tools
SERPAPI_API_KEY=
YUANFENJU_API_KEY=

# Session/cache
REDIS_URL=redis://redis:6379/
SESSION_TTL_SECONDS=600

# Password-only switch
SMS_PROVIDER=mock
SMS_DEBUG_CODE_ENABLED=false
SMS_HTTP_TIMEOUT_SECONDS=8

# Keep empty while SMS is disabled
SMS_ALIYUN_ACCESS_KEY_ID=
SMS_ALIYUN_ACCESS_KEY_SECRET=
SMS_ALIYUN_SIGN_NAME=
SMS_ALIYUN_TEMPLATE_CODE=
SMS_ALIYUN_REGION_ID=cn-hangzhou
SMS_ALIYUN_ENDPOINT=dysmsapi.aliyuncs.com
SMS_TEMPLATE_PARAM_CODE_KEY=code

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=fortune_telling
MYSQL_USER=fortune_app
MYSQL_PASSWORD=fortune_app_dev
MYSQL_ROOT_PASSWORD=replace_me

# Local vector store
VECTOR_DB_PATH=./local_qdrand
VECTOR_COLLECTION_NAME=local_documents
