# 大模型（阿里百炼 OpenAI 兼容）
DASHSCOPE_API_KEY=${DASHSCOPE_API_KEY}

# 搜索工具
SERPAPI_API_KEY=${SERPAPI_API_KEY}

# 国学接口
YUANFENJU_API_KEY=${YUANFENJU_API_KEY}

# Redis 会话存储
REDIS_URL=redis://127.0.0.1:6379/
SESSION_TTL_SECONDS=600
# 验证码是否回传 debug_code（开发 true，生产建议 false）
SMS_DEBUG_CODE_ENABLED=true
# 短信通道（mock / aliyun）
SMS_PROVIDER=mock
SMS_HTTP_TIMEOUT_SECONDS=8
# 阿里云短信（SMS_PROVIDER=aliyun 时必填）
SMS_ALIYUN_ACCESS_KEY_ID=
SMS_ALIYUN_ACCESS_KEY_SECRET=
SMS_ALIYUN_SIGN_NAME=
SMS_ALIYUN_TEMPLATE_CODE=
SMS_ALIYUN_REGION_ID=cn-hangzhou
SMS_ALIYUN_ENDPOINT=dysmsapi.aliyuncs.com
# 短信模板中验证码变量名（通常是 code）
SMS_TEMPLATE_PARAM_CODE_KEY=code

# MySQL（开发联调）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DB=fortune_telling
MYSQL_USER=fortune_app
MYSQL_PASSWORD=fortune_app_dev
MYSQL_ROOT_PASSWORD=root_dev_only_change_me

# 本地向量库
VECTOR_DB_PATH=./local_qdrand
VECTOR_COLLECTION_NAME=local_documents

# Cloudflare 命名隧道（固定域名）
# 在 Cloudflare Zero Trust 创建 Named Tunnel 后复制 token
CLOUDFLARED_TUNNEL_TOKEN=
